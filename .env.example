# Copy to .env (gitignored) and fill in to run the REAL eval (scripts/real_eval.sh).
# Cross-provider demo: the product-under-test runs on OpenAI GPT; the judge is Claude.

ANTHROPIC_API_KEY=sk-ant-...      # required — the Claude LLM-as-judge
OPENAI_API_KEY=sk-...             # required for cross-provider — the GPT product-under-test

